generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id        Int      @id @default(autoincrement())
  date      String   // display text, e.g. "SATURDAY JUNE 13TH"
  startDate DateTime? // real calendar date — used for sorting + auto-hiding past events
  city      String
  venue     String
  supports  String?
  rsvpUrl   String?
  ticketsUrl String?
  imageUrl  String?
  soldOut   Boolean  @default(false)
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// First-party click tracking — owned data, queryable per event, exposed via /api/stats.
model Click {
  id        Int      @id @default(autoincrement())
  eventId   Int?
  kind      String   // "ticket" | "rsvp" | other
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([kind])
}

model Album {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  coverUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  photos    Photo[]
}

model Photo {
  id        Int      @id @default(autoincrement())
  url       String
  caption   String?
  order     Int      @default(0)
  albumId   Int
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
